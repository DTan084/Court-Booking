# ============================================
# Court Booking - Environment Variables
# ============================================

# App
NODE_ENV=development
PORT=3001

# Frontend URL (CORS)
FE_URL=http://localhost:3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=court_booking
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0
REDIS_APP_PREFIX=cb:
REDIS_TLS_ENABLED=false
REDIS_CONNECT_TIMEOUT_MS=2000
REDIS_COMMAND_TIMEOUT_MS=2000
REDIS_ENABLE_OFFLINE_QUEUE=false
REDIS_MAX_RETRIES_PER_REQUEST=1
REDIS_QUEUE_DB=1
REDIS_QUEUE_PREFIX=bull
REDIS_QUEUE_ENABLE_OFFLINE_QUEUE=true

# JWT
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Booking Configuration
BOOKING_MIN_CANCEL_HOURS=2
BOOKING_MAX_DURATION_HOURS=8
BOOKING_JOB_SCHEDULER_ENABLED=true
BOOKING_JOB_SCHEDULER_LOCK_TTL_MS=30000

# Payment Configuration
# Keep empty to disable all providers safely on first deploy.
# Example: VNPAY,MOMO,PAYPAL
PAYMENT_PROVIDERS_ENABLED=
PAYMENT_RECONCILE_INTERVAL_MINUTES=5
PAYMENT_RECONCILE_STALE_MINUTES=10
PAYMENT_JOB_SCHEDULER_ENABLED=true
PAYMENT_JOB_SCHEDULER_LOCK_TTL_MS=30000

# VNPay (sandbox example values)
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/checkout/return/vnpay

# MoMo (sandbox example values)
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_API_URL=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:3000/checkout/return/momo
# Use ngrok public URL for real provider callbacks to local:
# MOMO_IPN_URL=https://<your-ngrok-subdomain>.ngrok-free.app/api/v1/payments/momo/webhook
MOMO_IPN_URL=

# PayPal (sandbox example values)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_API_URL=https://api-m.sandbox.paypal.com
PAYPAL_WEBHOOK_VERIFY_STRICT=true

# Next.js Frontend
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000
